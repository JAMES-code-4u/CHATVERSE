\nimport { useAuth } from \"./AuthContext\";\r\n\r\nconst SocketContext = createContext();\r\n\r\nexport const SocketProvider = ({ children }) => {\r\n  const { token, user } = useAuth();\r\n  const socketRef = useRef(null);\r\n  const [onlineUsers, setOnlineUsers] = useState([]);\r\n  const [incomingCall, setIncomingCall] = useState(null);\r\n\r\n  useEffect(() => {\r\n    if (token && user) {\r\n      socketRef.current = io(\r\n        process.env.REACT_APP_SERVER_URL || \"http://localhost:5000\",\r\n        { auth: { token }, transports: [\"websocket\"] }\r\n      );\r\n\r\n      socketRef.current.on(\"onlineUsers\", (users) => setOnlineUsers(users));\r\n\r\n      socketRef.current.on(\"incomingCall\", (data) => setIncomingCall(data));\r\n\r\n      socketRef.current.on(\"callEnded\", () => setIncomingCall(null));\r\n\r\n      return () => {\r\n        socketRef.current?.disconnect();\r\n      };\r\n    }\r\n  }, [token, user]);\r\n\r\n  const isOnline = (userId) => onlineUsers.includes(userId?.toString());\r\n\r\n  return (\r\n    <SocketContext.Provider value={{ socket: socketRef.current, onlineUsers, isOnline, incomingCall, setIncomingCall }}>\r\n      {children}\r\n    </SocketContext.Provider>\r\n  );\r\n};\r\n\r\nexport const useSocket = () => useContext(SocketContext);"],"mappings":"AAAA,MAAO,CAAAA,KAAK,EAAIC,aAAa,CAAEC,UAAU,CAAEC,SAAS,CAAEC,MAAM,CAAEC,QAAQ,KAAQ,OAAO,CACrF,OAASC,EAAE,KAAQ,kBAAkB,CACrC,OAASC,OAAO,KAAQ,eAAe,CAAC,OAAAC,GAAA,IAAAC,IAAA,yBAExC,KAAM,CAAAC,aAAa,cAAGT,aAAa,CAAC,CAAC,CAErC,MAAO,MAAM,CAAAU,cAAc,CAAGC,IAAA,EAAkB,IAAjB,CAAEC,QAAS,CAAC,CAAAD,IAAA,CACzC,KAAM,CAAEE,KAAK,CAAEC,IAAK,CAAC,CAAGR,OAAO,CAAC,CAAC,CACjC,KAAM,CAAAS,SAAS,CAAGZ,MAAM,CAAC,IAAI,CAAC,CAC9B,KAAM,CAACa,WAAW,CAAEC,cAAc,CAAC,CAAGb,QAAQ,CAAC,EAAE,CAAC,CAClD,KAAM,CAACc,YAAY,CAAEC,eAAe,CAAC,CAAGf,QAAQ,CAAC,IAAI,CAAC,CAEtDF,SAAS,CAAC,IAAM,CACd,GAAIW,KAAK,EAAIC,IAAI,CAAE,CACjBC,SAAS,CAACK,OAAO,CAAGf,EAAE,CACpBgB,OAAO,CAACC,GAAG,CAACC,oBAAoB,EAAI,uBAAuB,CAC3D,CAAEC,IAAI,CAAE,CAA